# Arduino Multi-Motor Loop Code:

// ----------------------------------------
// multi_motor_loop_smooth.ino
// ----------------------------------------
// - 2 Servo motors (servo1, servo2)
// - 1 DC motor (constant low-speed clockwise)
// - Serial signal "CAPTURE" to trigger Python screenshot or camera
//
// Wiring:
// - Servo1 signal -> Pin 9
// - Servo2 signal -> Pin 10
// - DC motor DIR  -> Pin 4
// - DC motor PWM  -> Pin 3 (PWM)
// - Common ground between Arduino, servo power, and DC motor driver
// ----------------------------------------

#include <Servo.h>

// ---------- CONFIG ----------
const uint8_t SERVO1_PIN = 9;
const uint8_t SERVO2_PIN = 10;

const uint8_t DC_DIR_PIN  = 4;   // H-bridge direction (HIGH = CW)
const uint8_t DC_PWM_PIN  = 3;   // PWM control pin

const int DC_SPEED = 100;        // (0–255) low speed
const int SERVO_STEP_DELAY = 5;  // ms per degree for smooth motion
const int LOOP_DELAY_MS = 1000;  // delay between cycles (ms)

Servo servo1;
Servo servo2;
// ----------------------------

// Function for smooth servo movement
void smoothMove(Servo &servo, int fromPos, int toPos, int stepDelay) {
  if (fromPos < toPos) {
    for (int pos = fromPos; pos <= toPos; pos++) {
      servo.write(pos);
      delay(stepDelay);
    }
  } else {
    for (int pos = fromPos; pos >= toPos; pos--) {
      servo.write(pos);
      delay(stepDelay);
    }
  }
}

void setup() {
  Serial.begin(9600);

  // Attach servos
  servo1.attach(SERVO1_PIN);
  servo2.attach(SERVO2_PIN);

  // Set initial positions
  servo1.write(90);
  servo2.write(0);
  delay(1000);

  // DC motor setup
  pinMode(DC_DIR_PIN, OUTPUT);
  pinMode(DC_PWM_PIN, OUTPUT);

  // Start DC motor clockwise at low speed
  digitalWrite(DC_DIR_PIN, HIGH);
  analogWrite(DC_PWM_PIN, DC_SPEED);

  Serial.println("System Initialized");
}

void loop() {
  // 1️⃣ Rotate servo1 90° → 150° (clockwise)
  smoothMove(servo1, 90, 150, SERVO_STEP_DELAY);
  delay(500);

  // 2️⃣ Rotate servo2 0° → 180° (clockwise)
  smoothMove(servo2, 0, 180, SERVO_STEP_DELAY);
  delay(500);

  // 3️⃣ Rotate servo1 150° → 90° (anticlockwise)
  smoothMove(servo1, 150, 90, SERVO_STEP_DELAY);
  delay(500);

  // 4️⃣ Trigger capture signal for Python
  Serial.println("CAPTURE");  // Python listens for this message
  delay(500);

  // 5️⃣ Smoothly return servo2 back to 0° (anticlockwise)
  smoothMove(servo2, 180, 0, SERVO_STEP_DELAY);

  // Optional: relax servos to avoid jitter
  servo1.detach();
  servo2.detach();
  delay(1000);
  servo1.attach(SERVO1_PIN);
  servo2.attach(SERVO2_PIN);

  delay(LOOP_DELAY_MS);

  // DC motor keeps running continuously
}
